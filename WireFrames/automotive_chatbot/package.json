{
  "name": "automotive-chatbot-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname localhost",
    "build": "next build",
    "start": "next start",

    "lint": "next lint",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:all-with-rasa": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:rasa\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && \"..\\.venv\\Scripts\\python.exe\" -m uvicorn api.main:app --reload --host localhost --port 8000",
    "dev:rasa": "cd backend && ../.venv/Scripts/python.exe -m rasa run --enable-api --cors \"*\" --port 5005 -i localhost",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "db:setup": "python mongodb_setup_simple.py",
    "db:check": "python -c \"import pymongo; print('MongoDB connection OK')\"",
    "status": "echo 'Checking services...' && curl -f http://localhost:3000 && curl -f http://localhost:8000/health && curl -f http://localhost:5005/status"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.1",
    "autoprefixer": "^10.4.17",
    "axios": "^1.6.7",
    "concurrently": "^8.2.2",
    "next": "^15.3.3",
    "postcss": "^8.4.35",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.50.1",
    "tailwindcss": "^3.4.1",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.8.3"
  }
}
